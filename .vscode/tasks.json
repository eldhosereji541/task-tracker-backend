{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start Docker Dev",
            "type": "shell",
            "command": "docker compose up --build",
            "runOptions": {
                "runOn": "folderOpen"
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "docker"
            },
            "isBackground": true,
            "problemMatcher": [
                {
                    "pattern": {
                        "regexp": "^$"
                    },
                    "background": {
                        "activeOnStart": true,
                        "beginsPattern": "Starting",
                        "endsPattern": "Listening on"
                    }
                }
            ]
        },
        {
            "label": "Stop Docker Dev",
            "type": "shell",
            "command": "docker compose down",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        }
    ]
}
