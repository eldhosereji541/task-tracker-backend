# GraphQL schema

type Task {
  id: ID!
  title: String!
  description: String
  status: String!
  createdAt: String!
  updatedAt: String!
  Deleted: Boolean!
}

type Query {
  tasks(status: String): [Task!]!
}

type Mutation {
  createTask(title: String!, description: String, status: String!): Task!
  updateTask(id: ID!, title: String, description: String, status: String): Task!
  deleteTask(id: ID!): Boolean!
}
